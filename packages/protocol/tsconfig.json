{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["esnext"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"strict": true,
		"noEmit": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	},
	"include": ["src"]
}
