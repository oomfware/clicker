{
	"name": "@oomfware/clicker-extension",
	"version": "0.0.0",
	"private": true,
	"description": "browser extension for clicker",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
