{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["esnext"],
		"types": ["node"],
		"moduleDetection": "force",
		"module": "preserve",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"strict": true,
		"noUnusedLocals": true,
		"noEmit": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"skipLibCheck": true
	},
	"include": ["src"]
}
